# ===========================================================
# Troan Digital — Apache hardening & performance (.htaccess)
# Safe for cPanel / Apache shared hosting.
# ===========================================================

# ---- Force HTTPS + canonical www ----
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Redirect http -> https
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ---- Default document ----
DirectoryIndex index.html

# ---- Disable directory listing ----
Options -Indexes

# ---- Security response headers ----
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  # HSTS — only enable once HTTPS is confirmed working (1 year)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"
  # Content Security Policy — allows Google Fonts and the FormSubmit endpoint
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://formsubmit.co; form-action 'self' https://formsubmit.co; base-uri 'self'; object-src 'none'; frame-ancestors 'self'"
  # Don't leak the framework/version
  Header unset X-Powered-By
  Header always unset X-Powered-By
</IfModule>

# ---- Block access to sensitive / dotfiles ----
<FilesMatch "(^\.|\.(md|yml|yaml|json|gitignore)$)">
  Require all denied
</FilesMatch>
# Re-allow the site's own data.js (it is a normal script, not config)
<Files "data.js">
  Require all granted
</Files>

# ---- GZIP compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ---- Browser caching ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
